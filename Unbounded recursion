def knap(i,capacity,val,wt):
    if i==len(val):
        return 0
    take=0
    if wt[i]<=capacity:
        take=val[i]+knap(i,capacity-wt[i],val,wt)
    notake=knap(i+1,capacity,val,wt)
    return max(take,notake)
def knapsack(capacity,val,wt):
    return knap(0,capacity,val,wt)
val=[1,1]
wt=[2,1]
capacity=3
print(knapsack(capacity,val,wt))

